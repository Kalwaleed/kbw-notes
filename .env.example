# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local development only. Keeps production auth intact because this is ignored
# unless Vite is running in dev mode.
VITE_LOCAL_AUTH_BYPASS=false

# Playwright e2e against a Vercel-protected URL (production or preview).
# Only needed when PLAYWRIGHT_BASE_URL points at a deployment behind
# Vercel Deployment Protection. Get the value from the Vercel dashboard:
# Settings → Deployment Protection → Protection Bypass for Automation.
# Never commit the actual value. Treat it like a production credential.
# VERCEL_BYPASS_SECRET=
# PLAYWRIGHT_BASE_URL=https://kalwaleed.com
